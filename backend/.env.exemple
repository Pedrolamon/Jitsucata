# string de conexão com o PostgreSQL
# formato típico: postgres://usuario:senha@host:porta/nome_do_banco
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres

# segredo usado para assinar/verificar os tokens JWT
# use uma cadeia longa/generada aleatoriamente
JWT_SECRET=fdofjaodjfdmfmsdnfidnfdsmposp

# (opcional) validade do token, aceita as mesmas unidades do jsonwebtoken
# se não definido usa "1d"
JWT_EXPIRES_IN=7d